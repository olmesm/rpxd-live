{
  "name": "rpxd-monorepo",
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*",
    "e2e",
    "docs-site"
  ],
  "scripts": {
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "build": "bun --filter='./packages/*' run build",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "@vitejs/plugin-rsc": "^0.5.27",
    "bun-types": "^1.3.14",
    "react-server-dom-webpack": "^19.2.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "zod": "^4.4.3",
    "zshy": "^0.7.3"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "react-server-dom-webpack": "^19.2.1"
  }
}
